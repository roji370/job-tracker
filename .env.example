# ─── Database ────────────────────────────────────────────────────────────────
# [REQUIRED] — Must be set. No defaults accepted in production.
POSTGRES_DB=jobtracker
POSTGRES_USER=jobtracker
# Use a strong random password: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# SQLAlchemy URL (auto-built in docker-compose; override here for local dev)
DATABASE_URL=postgresql+asyncpg://jobtracker:CHANGE_ME_STRONG_PASSWORD_HERE@localhost:5432/jobtracker

# ─── API Authentication ──────────────────────────────────────────────────────
# [REQUIRED IN PRODUCTION] — All API clients must send header: X-API-Key: <value>
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable (dev only — will print a loud warning)
API_KEY=

# ─── Twilio / WhatsApp ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+1234567890

# ─── Email (SMTP / Gmail) ────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_TO=recipient@example.com

# ─── App ─────────────────────────────────────────────────────────────────────
# [REQUIRED IN PRODUCTION] — Must be changed from default.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE

ENVIRONMENT=production

# [REQUIRED IN PRODUCTION] — Must be your actual domain(s), NOT localhost
# Example: ALLOWED_ORIGINS=https://myapp.example.com,https://www.myapp.example.com
ALLOWED_ORIGINS=https://your-domain.com

# ─── Scheduler ───────────────────────────────────────────────────────────────
SCHEDULER_INTERVAL_HOURS=6

# ─── AI Matching ─────────────────────────────────────────────────────────────
# Minimum score (%) to trigger notifications
MATCH_THRESHOLD=70.0
